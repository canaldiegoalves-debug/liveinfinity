{
  "manifest_version": 3,
  "name": "Live Infinity",
  "version": "4.2.2",
  "description": "Automação inteligente para lives de vendas.",
  "minimum_chrome_version": "120",
  "permissions": [
    "notifications",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.tiktok.com/*",
    "https://api.telegram.org/*",
    "https://api.valoranegocios.com.br/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tiktok.com/*"
      ],
      "js": [
        "src/shared/constants.js",
        "src/content/liveflow-core.js",
        "src/content/detector.js",
        "src/content/controller.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Abrir Live Infinity"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
